{
  "name": "instagramclone",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "render": "(cd client && npm i && npm run build)&& (cd backend && npm i )",
    "start": "cd backend && npm start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "(npm run build --workspace client)",
    "postinstall": "npm run build",
    "build:client": "(cd client && npm i && npm run build)&& (mv client/build backend/build)"
  },
  "workspaces": [
    "client",
    "backend"
  ],
