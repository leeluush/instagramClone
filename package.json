{
  "name": "instagramclone",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "if [ \"$NODE_ENV\" = \"production\" ]; then npm run start-server; else npm run dev; fi",
    "build": "npm run install-server && npm run install-client && npm run build-client && mkdir -p backend/client && mv client/build backend/client/build",
    "install-server": "cd backend && npm install",
    "start-server": "cd backend && node server.js",
    "dev": "cd backend && npm run dev",
    "install-client": "cd client && npm install",
    "build-client": "cd client && npm run build",
    "start-client": "cd client && npm run start"
  },
  "workspaces": [
    "client",
    "backend"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leeluush/instagramClone.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/leeluush/instagramClone/issues"
  },
  "homepage": "https://github.com/leeluush/instagramClone#readme",
  "dependencies": {
    "nodemailer": "^6.9.9",
    "pug": "^3.0.2"
  }
}
